# ==========================================
# 0. DATABASE CONFIGURATION (Postgres)
# ==========================================
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ==========================================
# 1. IMAGE STORAGE (Cloudflare R2)
# ==========================================
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="satellite-data"
# Optional but recommended (fastest): public base URL for HTTP Range requests.
# If omitted, backend will automatically use short-lived presigned URLs (still supports HTTP Range).
# Example (custom domain): R2_PUBLIC_URL="https://r2.your-domain.com"
# Example (r2.dev):       R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"
R2_PUBLIC_URL=""

# ==========================================
# 2. FEATURE FLAGS & PERFORMANCE
# ==========================================
PORT=8000
NODE_ENV=development
USE_PREBUILT_GRID=true
USE_WORKER_POOL=true
WORKER_POOL_SIZE=4

# ==========================================
# 3. AIRFLOW & PIPELINE CONFIG
# ==========================================
AIRFLOW_UID=50000
_PIP_ADDITIONAL_REQUIREMENTS="pdfplumber pandas requests"
# Optional: legacy local data path (backend and training use R2, not local)
# SOURCE_DIR="../data/MergedDatabase"
EE_PROJECT_ID="your_earth_engine_project"
