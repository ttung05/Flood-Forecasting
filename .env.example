# ==========================================
# 0. DATABASE CONFIGURATION (Supabase Postgres)
# Used by: upload_postgres.py, api.js
# Connection String: postgres://postgres.[project_id]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# ==========================================
DATABASE_URL=


# ==========================================
# 1. IMAGE STORAGE (Cloudflare R2)
# Used by: Frontend (direct URL) or Image upload scripts
# ==========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Path to the data folder you want to upload (default: ./data/FloodData)
SOURCE_DIR=./data/FloodData
