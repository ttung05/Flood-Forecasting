    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "fast-json-stringify": "^6.3.0",
    "geotiff": "^3.0.3",
    "p-limit": "^7.3.0",
    "proj4": "^2.20.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
